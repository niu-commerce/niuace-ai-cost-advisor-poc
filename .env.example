APP_NAME="NiuAce AI Cost Advisor"

# Optional AI providers. Leave blank to use deterministic mock responses.
AI_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4.1-nano
ANTHROPIC_API_KEY=your-anthropic-api-key
CLAUDE_MODEL=claude-haiku-4-5

# Optional MySQL. Leave MYSQL_ENABLED=false for the POC mock dataset.
MYSQL_ENABLED=false
MYSQL_HOST=127.0.0.1
MYSQL_PORT=13306
MYSQL_USER=amaseng
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=max_purchasing
MYSQL_DEFAULT_COMPANY_ID=1452


